<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.locus.news-feedback</string>

    <!-- フィードバック分析 → news_config.py 自動改善 -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/takemi/Projects/locus-project/locus/news_feedback.sh</string>
    </array>

    <!-- 毎日 22:00 に実行 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>22</integer>
        <key>Minute</key><integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/Users/takemi/.local/bin:/opt/homebrew/bin</string>
        <key>HOME</key>
        <string>/Users/takemi</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/locus-news-feedback.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/locus-news-feedback-error.log</string>
</dict>
</plist>
