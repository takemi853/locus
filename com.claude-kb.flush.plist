<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude-kb.flush</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/takemi/.local/bin/uv</string>
        <string>run</string>
        <string>--directory</string>
        <string>/Users/takemi/Projects/app/claude-memory-compiler</string>
        <string>python</string>
        <string>/Users/takemi/Projects/app/claude-memory-compiler/scripts/flush_periodic.py</string>
    </array>

    <!-- 5分ごとに実行 -->
    <key>StartInterval</key>
    <integer>300</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/tmp/claude-kb-flush.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/claude-kb-flush-error.log</string>
</dict>
</plist>
